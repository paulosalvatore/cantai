# Boraoke environment variables — copy to `.env` and fill in.
# The `.env` file is gitignored; never commit real credentials.

# ─── Canonical domain (TICKET-33) ────────────────────────────────────────────
# Production canonical origin is https://boraoke.com. next.config.ts permanently
# (308) redirects the old cantai-snowy.vercel.app apex to it, preserving path.
# When Google OAuth / NextAuth are wired, set NEXTAUTH_URL to the canonical
# origin and add boraoke.com to the OAuth authorized origins + redirect URIs.
# NEXTAUTH_URL=https://boraoke.com

# ─── Persistence (TICKET-6) ──────────────────────────────────────────────────
# Store driver. Leave unset to auto-select: `upstash` when the Upstash REST URL
# below is present, otherwise the in-memory driver (no credentials needed).
# Force a driver with `memory` or `upstash`.
# STORE_DRIVER=upstash

# Upstash Redis (durable, shared queue store). Provisioned via the Vercel
# Marketplace Upstash integration, which injects these into the deployment env.
# Required only for the `upstash` driver; unset = in-memory driver.
# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-rest-token>

# ─── YouTube search (TICKET-8) ───────────────────────────────────────────────
# YouTube Data API v3 key (server-side only — TICKET-8 in-app search).
# Leave empty for local dev / CI: the app builds and runs in degraded mode
# (free-text search shows the fallback copy; paste-a-YouTube-link still works).
# Provision in Google Cloud (enable "YouTube Data API v3", create an API key,
# restrict to that API + your server referrers) and set it in Vercel env + local .env.
YOUTUBE_API_KEY=

# ─── Feedback intake (TICKET-11) ─────────────────────────────────────────────
# Server-side admin token guarding the house read path (GET /api/feedback?since=)
# and the status-update write path (PATCH /api/feedback). NEVER shipped to the
# client. Unset = the admin endpoints are fail-closed (deny all). Generate a long
# random value, e.g. `openssl rand -hex 32`.
# FEEDBACK_ADMIN_TOKEN=<long-random-secret>

# ─── Host controls (TICKET-7) ────────────────────────────────────────────────
# Shared admin token the venue host enters once at /admin to control the queue
# (skip / remove / reorder / pause). Set a strong random value in Vercel + local
# `.env`. If unset: development accepts a well-known dev fallback token so the
# app boots with zero secrets; PRODUCTION locks host controls until this is set.
# Generate one with:  openssl rand -base64 32
# HOST_TOKEN=<your-strong-random-token>

# ─── Rooms (TICKET-9) ────────────────────────────────────────────────────────
# Abuse guards on unauthenticated room creation (POST /api/rooms).
# Per-IP creation throttle: rooms per IP per hour. Default 3. In `next dev` the
# throttle is skipped unless this is explicitly set (zero-config local dev).
# ROOM_CREATE_LIMIT=3
# Global room-creation ceiling (hard cap; 503 "estamos lotados" when reached).
# Default 500. Rooms are never deleted yet — TTL/idle-expiry is a #14 follow-up.
# ROOM_MAX=500

# ─── Telemetry (TICKET-12) ───────────────────────────────────────────────────
# Anonymous product events (no PII) reuse the SAME store driver + Upstash vars
# above — no extra provisioning. Memory driver (default) = events are volatile.
# Kill switch: set to 1 to disable all telemetry emission (read at call time).
# TELEMETRY_DISABLED=1
